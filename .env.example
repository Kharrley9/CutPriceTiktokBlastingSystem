# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (send /myid to the bot to get it)
ADMIN_TELEGRAM_ID=your_id_here

# Server Configuration
PORT=3000
# Public URL for click tracking (e.g. your ngrok URL or VPS domain)
PUBLIC_URL=http://localhost:3000

# Blast Configuration
BLAST_TIME=00:00
BLAST_TIMEZONE=Asia/Kuala_Lumpur
MAX_MEMBERS=100
LINKS_PER_BLAST=10
